# Network
PORT=8000
PORT_HEALTH=8000
HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO

# API behavior
RESPONSE_MODE=binary
REQUEST_TIMEOUT_SECONDS=25
MAX_TEXT_CHARS=4000

# TTS defaults
DEFAULT_VOICE=af_heart
DEFAULT_SPEED=1.0
MODEL_LANG=en-us
SAMPLE_RATE=24000
KOKORO_REPO_ID=hexgrad/Kokoro-82M
KOKORO_DEVICE=cuda
ALLOW_CPU_FALLBACK=false
SUPPORTED_VOICES=

# Text splitting
ENABLE_TEXT_SPLITTING=true
MAX_CHARS_PER_CHUNK=180

# Metadata
APP_NAME=kokoro-runpod-tts
APP_VERSION=1.0.0
